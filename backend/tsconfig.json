{
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "module": "CommonJS", // Sử dụng CommonJS để tương thích với Node.js và TypeORM
    "moduleResolution": "Node", // Phù hợp với CommonJS
    "target": "ES2020", // Tương thích với Node.js LTS (18.x hoặc 20.x)
    "outDir": "dist", // Thư mục output
    "rootDir": "src", // Chỉ định thư mục gốc để giữ cấu trúc dist/src
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".", // Hỗ trợ alias
    "paths": {
      "~/*": ["src/*"] // Alias cho import
    },
    "resolveJsonModule": true // Nếu bạn import file JSON
  },
  "include": ["src/**/*", "src/type.d.ts"], // Bao gồm tất cả file trong src và type.d.ts
  "exclude": ["node_modules", "dist"] // Loại bỏ các thư mục không cần biên dịch
}
